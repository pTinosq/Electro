<Window x:Name="window" x:Class="ElectroImageViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ElectroImageViewer"
    mc:Ignorable="d"
    Title="MainWindow" Height="450" Width="800"
    KeyDown="Window_KeyDown"
    Cursor="ScrollAll"
        >

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>


    <Grid Background="White" x:Name="electroMain" >
        <local:TerminalControl x:Name="terminalControl" Margin="0,0,0,0" Panel.ZIndex="5"
            Visibility="{Binding ControlVisibility, RelativeSource={RelativeSource Self}}" RenderTransformOrigin="0.497,0.531" />
        <local:ZoomBorder x:Name="border" ClipToBounds="True" Background="#FFAFAFAF">
            <Image x:Name="electroImage" Source="{Binding WorkspaceDisplayImage}"
            Panel.ZIndex="2"  >
            </Image>
        </local:ZoomBorder>
    </Grid>
</Window>